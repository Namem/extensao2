{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "PostgreSQL (Docker)",
      "runtimeExecutable": "docker-compose",
      "runtimeArgs": ["up", "-d"],
      "port": 5433
    },
    {
      "name": "Django Backend",
      "runtimeExecutable": "python",
      "runtimeArgs": ["backend/manage.py", "runserver", "8000"],
      "port": 8000
    },
    {
      "name": "Flutter Web",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "-d", "web-server", "--web-port", "3000", "--web-hostname", "localhost"],
      "port": 3000
    }
  ]
}
